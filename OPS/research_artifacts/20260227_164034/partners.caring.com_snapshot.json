        - 'link "Time to Shine: How to Qualify for Caring Stars 2026" [ref=e540] [cursor=pointer]':
          - /url: /time-to-shine-how-to-qualify-for-caring-stars-2026
        - generic [ref=e541]:
          - generic [ref=e542]:
            - img [ref=e544]
